# Server
NODE_ENV=production
PORT=5000

# MongoDB Atlas – use either MONGO_URI (full URL) or DB_CONNECTION + DB_PASSWORD
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/<dbname>
# Or:
# DB_CONNECTION=mongodb+srv://<user>:<db_password>@cluster0.xxxxx.mongodb.net/<dbname>
# DB_PASSWORD=your_password

# JWT
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=6h
JWT_COOKIE_EXPIRES_IN=6

# Encryption
ENCRYPTION_ALGORITHM=aes-256-cbc
ENCRYPTION_IV_LENGTH=16
ALGORITHM=aes-256-cbc
IV_LENGTH=16
ENCRYPTION_KEY=32_character_encryption_key_here
HASH_SECRET=your_hash_secret

# Email (Mailtrap for dev, Brevo for prod)
EMAIL_FROM=your@email.com
EMAIL_HOST=sandbox.smtp.mailtrap.io
EMAIL_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=

# Production CORS (optional)
# FRONTEND_URL=https://your-frontend-domain.com

# Phase 5 — IoT & Attendance
# IOT_DEVICE_SECRET is required at startup (BE-CRIT-4). Generate a strong random secret.
IOT_DEVICE_SECRET=your_strong_random_iot_device_secret
# Leave IOT_HUB_CONNECTION_STRING empty to run in mock mode (no Azure required)
IOT_HUB_CONNECTION_STRING=
IOT_MOCK_MODE=true
IOT_CENTRAL_DEVICE_ID=FP-CENTRAL-01
ATTENDANCE_SESSION_DURATION_MINUTES=90
UNIVERSITY_TIMEZONE=Africa/Cairo
ATTENDANCE_OPEN_BEFORE_MINUTES=15
ATTENDANCE_CLOSE_AFTER_MINUTES=15
FINGERPRINT_MIN_CONFIDENCE=40
DEVICE_CLOCK_SKEW_SECONDS=120
QR_TOKEN_TTL_SECONDS=30
QR_TOKEN_GRACE_SECONDS=10
# Max templates per loadTemplates Direct Method (ESP32 MQTT ~8192 bytes; default 7)
IOT_TEMPLATES_PER_BATCH=7
